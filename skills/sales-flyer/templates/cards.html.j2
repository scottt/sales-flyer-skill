<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<title>{{ brand.name }} — messaging cards</title>
{{ font_face }}
<style>
  /* Each .card is screenshotted to one square PNG (default 1040x1040, LINE rich-message spec). */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: {{ font_css | default(font) }}; color: #0b0b0b; background: #ffffff; }
  .card { width: 1040px; height: 1040px; padding: 56px 60px; background: #f9f9f7; overflow: hidden; }

  .brand { font-size: 24px; letter-spacing: 6px; color: {{ brand.color }}; font-weight: 700; }

  /* card 1 — hero */
  .card-hero { background: {{ brand.color }}; color: #fff; }
  .card-hero .brand { color: #b7d3f6; }
  .card-hero h1 { font-size: 88px; font-weight: 900; line-height: 1.22; margin: 30px 0 26px; }
  .card-hero .sub { font-size: 34px; color: #cde2fb; line-height: 1.6; margin-bottom: 44px; }
  .vp { background: rgba(255,255,255,0.10); border: 1px solid rgba(255,255,255,0.22);
        border-radius: 14px; padding: 24px 30px; margin-bottom: 22px; }
  .vp .t { font-size: 33px; font-weight: 700; margin-bottom: 6px; }
  .vp .d { font-size: 25px; color: #cde2fb; line-height: 1.5; }

  h2 { font-size: 44px; font-weight: 900; color: {{ brand.color }}; margin-bottom: 26px;
       border-left: 10px solid {{ brand.accent }}; padding-left: 20px; line-height: 1.2; }
  .tiny { font-size: 18px; color: #898781; line-height: 1.5; }

  /* card 2 — jobs + stats */
  ul.jobs { list-style: none; margin-bottom: 34px; }
  ul.jobs li { background: #fcfcfb; border: 1px solid #e1e0d9; border-radius: 12px;
               padding: 16px 24px; margin-bottom: 14px; font-size: 27px; line-height: 1.45; }
  ul.jobs li b { color: {{ brand.color }}; }
  table.kpi { width: 100%; border-collapse: separate; border-spacing: 18px 0;
              table-layout: fixed; margin-left: -18px; }
  table.kpi td { background: #fcfcfb; border: 1px solid #e1e0d9; border-radius: 14px;
                 padding: 26px 18px 22px; text-align: center; vertical-align: top; }
  .kpi-label { font-size: 24px; color: #52514e; margin-bottom: 10px; }
  .kpi-value { font-size: 52px; font-weight: 900; line-height: 1.1; white-space: nowrap; }
  .kpi-value.long { font-size: 42px; }
  .kpi-unit { font-size: 22px; font-weight: 400; color: #898781; }
  .kpi-note { font-size: 19px; color: #898781; margin-top: 10px; line-height: 1.4; }
  .t-neutral { color: #0b0b0b; }
  .t-good { color: #006300; }
  .t-brand { color: {{ brand.color }}; }

  /* card 3 — pricing + CTA */
  table.price { width: 100%; border-collapse: separate; border-spacing: 0 16px; }
  table.price td { background: #fcfcfb; border: 1px solid #e1e0d9; padding: 20px 28px; vertical-align: middle; }
  td.p-name { border-radius: 12px 0 0 12px; border-right: none; width: 250px;
              font-size: 30px; font-weight: 900; color: {{ brand.color }}; }
  td.p-price { border-left: none; border-right: none; font-size: 34px; font-weight: 900; white-space: nowrap; }
  td.p-price .kpi-unit { font-size: 20px; }
  td.p-month { border-radius: 0 12px 12px 0; border-left: none; font-size: 22px; color: #52514e; width: 300px; }
  .badge { display: inline-block; background: #eda100; color: #0b0b0b; font-size: 20px; font-weight: 700;
           border-radius: 6px; padding: 2px 12px; margin-left: 10px; vertical-align: middle; }
  .offer { background: #eaf2fb; border-radius: 12px; padding: 20px 26px;
           font-size: 25px; margin: 10px 0 30px; line-height: 1.5; }
  .cta { background: {{ brand.color }}; color: #fff; border-radius: 16px; padding: 38px 42px; margin-top: 8px; }
  .cta h3 { font-size: 38px; font-weight: 900; line-height: 1.35; margin-bottom: 14px; }
  .cta .contact { font-size: 26px; color: #cde2fb; line-height: 1.55; }
  .qrbox { width: 190px; height: 190px; background: #fff; border-radius: 10px; float: right;
           margin-left: 34px; text-align: center; font-size: 20px; color: #898781; padding-top: 76px; }
  .qrbox img { width: 100%; height: 100%; border-radius: 10px; }
</style>
</head>
<body>

<div class="card card-hero">
  <div class="brand">{{ brand.name }}　{{ brand.tagline }}</div>
  <h1>{{ hero.headline_mobile | default(hero.headline) }}</h1>
  <div class="sub">{{ hero.subhead_mobile | default(hero.subhead) }}</div>
  {% for vp in value_props %}
  <div class="vp">
    <div class="t">{{ vp.title }}</div>
    <div class="d">{{ vp.body_mobile | default(vp.body) }}</div>
  </div>
  {% endfor %}
</div>

<div class="card">
  <h2>{{ jobs_title }}</h2>
  <ul class="jobs">
    {% for j in jobs %}
    <li><b>{{ j.name }}</b> — {{ j.desc_mobile | default(j.desc) }}</li>
    {% endfor %}
  </ul>
  <h2>{{ stats_title_mobile | default(stats_title) }}</h2>
  <table class="kpi"><tr>
    {% for s in stats %}
    {% set val = s.value_mobile | default(s.value) %}
    <td>
      <div class="kpi-label">{{ s.label }}</div>
      <div class="kpi-value t-{{ s.tone | default('neutral') }}{% if val | length > 7 %} long{% endif %}">{{ val }}{% if s.unit %}<span class="kpi-unit">{{ s.unit }}</span>{% endif %}</div>
      <div class="kpi-note">{{ s.note }}</div>
    </td>
    {% endfor %}
  </tr></table>
  {% if stats_source %}
  <div class="tiny" style="margin-top:18px;">{{ stats_source_mobile | default(stats_source) }}</div>
  {% endif %}
</div>

<div class="card">
  <h2>{{ pricing_title }}</h2>
  <table class="price">
    {% for p in pricing %}
    <tr>
      <td class="p-name">{{ p.tier }}{% if p.badge %}<span class="badge">{{ p.badge }}</span>{% endif %}</td>
      <td class="p-price">{{ p.price }}{% if p.price_unit %}<span class="kpi-unit"> {{ p.price_unit }}</span>{% endif %}</td>
      <td class="p-month">{{ p.recurring_mobile | default(p.recurring) }}</td>
    </tr>
    {% endfor %}
  </table>
  {% if pricing_offer %}
  <div class="offer">{{ pricing_offer }}<br><span class="tiny">{{ pricing_fineprint }}</span></div>
  {% endif %}
  <div class="cta">
    <div class="qrbox">{% if cta.qr %}<img src="{{ cta.qr }}" alt="QR">{% else %}QR code<br>(placeholder){% endif %}</div>
    <h3>{{ cta.headline_mobile | default(cta.headline) }}</h3>
    <div class="contact">{{ cta.contact_mobile | default(cta.contact) }}</div>
    <div class="contact" style="margin-top:10px;">{{ cta.reassurance_mobile | default(cta.reassurance) }}</div>
  </div>
</div>

</body>
</html>
